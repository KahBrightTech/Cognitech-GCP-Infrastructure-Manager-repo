# Local Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which might contain sensitive data
*.tfvars
*.tfvars.json

# But include example files
!examples.tfvars

# Ignore override files as they are usually used locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# Terraform lock file (include this in version control)
# .terraform.lock.hcl

# Terraform modules
.terraform/
.terraform.*

# Service account keys (NEVER commit these!)
*-key.json
*.key
*.pem
credentials.json

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Backup files
*.bak
*.orig
